# Copy this file to `.env` in the same directory and fill in real values.
# `docker compose` reads it automatically.

# Required. Generate with: openssl rand -hex 32
PALM_WORKER_TOKEN=CHANGE_ME_OPENSSL_RAND_HEX_32

# "stub" for Phase A, "mpirun" once PALM is compiled in a derived image.
PALM_WORKER_MODE=stub

# Only used when PALM_WORKER_MODE=mpirun.
PALM_BINARY=/opt/palm/bin/palm
PALM_MPI_NP=4

# Reported back to the Windows client for reproducibility metadata.
PALM_VERSION_LABEL=23.10
PALM_BUILD_FLAGS=-O3 -march=native
