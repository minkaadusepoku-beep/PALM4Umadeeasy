# /etc/palm-worker/worker.env — loaded by systemd via EnvironmentFile=
# Deploy this as /etc/palm-worker/worker.env with 0640 root:palmworker.
# Do NOT commit real tokens to git.

# --- Required ---------------------------------------------------------------
# Shared bearer secret. Must match PALM_REMOTE_TOKEN on the Windows client.
# Generate with: `openssl rand -hex 32`
PALM_WORKER_TOKEN=CHANGE_ME_OPENSSL_RAND_HEX_32

# --- Runtime ---------------------------------------------------------------
# "stub" (Phase A: echo the static driver back) or "mpirun" (real PALM).
PALM_WORKER_MODE=stub

# Root for per-run scratch directories; StateDirectory= in the unit file
# already creates /var/lib/palm-worker with the right permissions.
PALM_WORKER_JOBDIR=/var/lib/palm-worker/jobs

# --- Only when MODE=mpirun -------------------------------------------------
# Path to the compiled PALM binary.
PALM_BINARY=/opt/palm/bin/palm

# MPI ranks to request from mpirun.
PALM_MPI_NP=4

# --- Reproducibility metadata reported back to the Windows client ----------
PALM_VERSION_LABEL=23.10
PALM_BUILD_FLAGS=-O3 -march=native
